{
  "version": 2,
  "builds": [
    {
      "src": "server.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/noa/chat",
      "methods": ["POST", "OPTIONS"],
      "dest": "server.ts"
    },
    {
      "src": "/api/orders",
      "methods": ["GET"],
      "dest": "server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
